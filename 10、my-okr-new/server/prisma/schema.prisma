generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // 固定为相对于 server 根目录的 dev.db，限制连接数为 1 并设置超时时间，降低 SQLite 锁冲突概率
  // 对 SQLite 来说，这里的 query 参数会作为文件 URI 传递，Prisma 会忽略未知参数，但仍保持兼容
  url      = "file:./prisma/dev.db?connection_limit=1&socket_timeout=10000"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

// 产品工作底稿 OS - 核心模型
model PlanNode {
  id            Int        @id @default(autoincrement())
  title         String
  description   String?
  owner         String?    // '黄心怡' | '樊云川'
  level         Int        @default(1) // 1-6 (L1-L6)
  priority      String     @default("P1") // 'P0' | 'P1' | 'P2' | 'P3' | 'P4'
  
  // 层级结构与性能优化
  parentId      Int?       // 父节点 ID
  parent        PlanNode?  @relation("ParentChild", fields: [parentId], references: [id])
  children      PlanNode[] @relation("ParentChild")
  
  rootId        Int?       // 根节点 ID (Performance: avoid recursive queries)
  
  // 进度与状态
  plannedEndDate String?   // 上线时间 (e.g. '3月下旬', '1月内')
  actualEndDate  DateTime? // 实际完成时间
  planStatus     String?   @default("PLANNED")
  // 合法值：'PLANNED' | 'IN_PROGRESS' | 'IN_PROGRESS_CROSS_WEEK' | 'DONE' | 'DEFERRED' | 'CANCELLED'
  // IN_PROGRESS_CROSS_WEEK = 跨周进行中（本周未完成，周报锁定时自动滚入下周）
  // DEFERRED               = 延后（主动推迟，不自动滚入）
  // CANCELLED              = 废弃（不再执行）
  periodType     String?   // 'YEAR' | 'MONTH' | 'WEEK'
  
  // [New] 7层基因编码 (WBS DNA)
  planCategoryCode String? // L1: F-分类 (e.g. 01)
  objectiveCode    String? // L2: O-目标 (e.g. 01)
  krCode           String? // L3: KR-关键结果 (e.g. 01)
  detail1Code      String? // L4: D1-拆解一层 (e.g. 01)
  detail2Code      String? // L5: D2-拆解二层 (e.g. 01)
  monthCode        String? // L6: M-月度 (e.g. 01)
  weekCode         String? // L7: W-周度 (e.g. 01)

  // [New] 逻辑编码与分类
  nodeNumber     String?   @unique // 逻辑编码 (e.g. F01O01KR01D101D201M01W01)
  planCategory   String?   // 分类 (e.g. '工作', '生活') - 对应 planCategoryCode
  
  // 执行复盘字段 (Execution & Review)
  targetDate     DateTime? // 目标日期 (替代 plannedEndDate 的 String 类型?) 
  
  progress       Float     @default(0) // 0-100
  status         String    @default("PLANNED") // Enum: PLANNED, IN_PROGRESS, COMPLETED, PAUSED, CANCELLED
  // outputContent 已合并至 dataFeedback，如需保留请确认用途。
  // 用户指示: "保留 description 作为任务描述，但请确认 dataFeedback 才是执行结果的核心存放地。如果 outputContent 没用，请合并或删除"
  // 决策: 删除 outputContent，统一使用 dataFeedback
  
  // [New] Reporting Fields
  dataFeedback   String?   // 执行结果/数据反馈 (Core Output)
  issueLog       String?   // 问题记录（障碍/风险/复盘）

  // [New] 执行工时
  actualHours    Float?    // 实际工时（小时），L6 录入，上层汇总

  // [New] Management Audit
  evolutionTag   String?   // 'ORIGINAL', 'PLAN_OUTSIDE', 'STRATEGY_ADJUST', 'INHERITED'
  
  // [New] Schedule Linkage
  scheduleNodes  ScheduleNode[]

  // [New] DailyTask 关联
  dailyTasks     DailyTask[]

  // [New] DailySchedule 关联
  dailySchedules DailySchedule[] @relation("DailySchedulePlanNode")

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  @@index([rootId])
  @@index([periodType])
  @@index([updatedAt])
  @@index([status])
}

// ... (Existing Enums)

// [New] 日程节点 (Time Slots)
model ScheduleNode {
  id            Int       @id @default(autoincrement())
  date          String    // YYYY-MM-DD
  startTime     String    // HH:mm (e.g. "09:00")
  endTime       String    // HH:mm (e.g. "09:30")
  
  // Linkage
  relatedPlanId Int?
  relatedPlan   PlanNode? @relation(fields: [relatedPlanId], references: [id])
  
  // Content
  title         String?   // Optional snapshot or ad-hoc task
  remark        String?   // Process record / 备注
  category      String?   // [New] Manual Category (e.g. '工作', '生活') for AI Audit
  
  // Layout
  isMerged      Boolean   @default(false)
  span          Int       @default(1) // Number of 30-min slots
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([date])
  @@index([relatedPlanId])
}

// [New] 每日概览 (Daily View & AI Audit)
model DailySummary {
  id            Int       @id @default(autoincrement())
  date          String    @unique // YYYY-MM-DD
  
  // Part 1: Intention
  mit           String?   // Most Important Thing (每日核心目标)
  
  // Part 2: Reality (AI Generated)
  aiSummary     String?   // "今天忙了些啥"
  
  // Part 3: Audit (AI Generated)
  aiAudit       String?   // "知行合一评价"
  score         Int?      // 评分
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 每日工作日志 (用于工时计算)
model WorkLog {
  id            Int      @id @default(autoincrement())
  content       String   
  relatedNodeId Int?     
  startTime     DateTime?
  endTime       DateTime?
  // 业务字段落地（遵循 04:00 业务日规则）
  durationMinutes Int?
  priority        String?
  businessDate    String   // YYYY-MM-DD，业务日（00:00-03:59 回拨前一日）
  confidence      Float?
  createdAt     DateTime @default(now())
}

// 推送历史存档
model PushHistory {
  id           Int      @id @default(autoincrement())
  content      String   // 推送的 Markdown 内容
  status       String   // 'SUCCESS' | 'FAILED'
  platform     String   // 'WECHAT'
  
  // 报表维度增强
  reportType   String?  // 'WEEK' | 'HALF_MONTH' | 'MONTH' | 'YEAR'
  reportPeriod String?  // e.g. '2024-03-H1', '2024-W12'
  snapshotData String?  // JSON string: 报表生成时的全量任务快照
  
  createdAt    DateTime @default(now())
  
  @@index([reportType, reportPeriod])
}

/// LoveMe OS — 通用 WBS 节点模型（七层）
model WBSNode {
  id         Int       @id @default(autoincrement())
  name       String
  level      Int       // 1-7, 对应 WBS 七层

  /// 逻辑编号，例如：L1-01, L4-02-01
  nodeNumber String    @unique

  /// 自引用形成树结构
  parentId   Int?
  parent     WBSNode?  @relation("WBSParentChild", fields: [parentId], references: [id])
  children   WBSNode[] @relation("WBSParentChild")

  /// 关联执行层任务/活动
  activities Activity[]

  /// 进度（0-100）
  progress   Float     @default(0)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([level])
  @@index([parentId])
  @@index([nodeNumber])
  @@index([progress])
}

/// 执行层任务 / 活动（挂在某个 WBS 节点下）
model Activity {
  id          Int      @id @default(autoincrement())

  /// 任务名称（语义解析得到的 taskName）
  title       String?

  /// 所属 WBS 节点（通常是 L5/L6/L7）
  wbsNodeId   Int
  wbsNode     WBSNode  @relation(fields: [wbsNodeId], references: [id])

  /// 是否为计划内任务（精力哨兵逻辑）
  isPlanned   Boolean  @default(true)

  /// 计划时间
  plannedStart DateTime?
  plannedEnd   DateTime?

  /// 实际发生时间
  actualStart  DateTime?
  actualEnd    DateTime?

  /// 预估时长（分钟）
  durationMinutes Int? @default(0)

  /// 业务日（遵循 04:00 业务日规则），格式：YYYY-MM-DD
  businessDate String?

  /// 状态：进行中、已完成、风险 等（使用字符串，后续可迁移为 Enum）
  status      String   @default("PLANNED")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([wbsNodeId])
  @@index([status])
  @@index([businessDate])
}

// ── 每日执行任务（关联 PlanNode，记录具体时间段与维度）──────────────
model DailyTask {
  id          Int       @id @default(autoincrement())

  /// 关联的 PlanNode（通常是 L6 执行节点）
  planNodeId  Int
  planNode    PlanNode  @relation(fields: [planNodeId], references: [id])

  /// 业务日期，格式 YYYY-MM-DD
  date        String

  /// 开始时间，格式 HH:mm
  startTime   String?

  /// 结束时间，格式 HH:mm
  endTime     String?

  /// 实际工时（小时），可由 startTime/endTime 计算或手动录入
  actualHours Float?

  /// 工作维度：'工作' | '生活' | '成长'
  dimension   String?

  /// 执行备注 / 产出
  remark      String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([planNodeId])
  @@index([date])
}

// ── 每日日程安排（时间块，可关联 PlanNode）────────────────────────────
model DailySchedule {
  id          Int       @id @default(autoincrement())

  /// 业务日期，格式 YYYY-MM-DD
  date        String

  /// 开始时间，格式 HH:mm（如 "09:00"）
  startTime   String

  /// 结束时间，格式 HH:mm（如 "09:30"）
  endTime     String

  /// 任务名称（可独立填写，也可从关联节点继承）
  taskName    String?

  /// 关联的 PlanNode（可选，关联后可追溯到 WBS 层级）
  nodeId      Int?
  planNode    PlanNode? @relation("DailySchedulePlanNode", fields: [nodeId], references: [id])

  /// 工作维度：'工作' | '生活' | '成长'
  dimension   String?

  /// 备注
  remark      String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([date])
  @@index([nodeId])
}

// ── 审计报告（AI 生成的周/月/年总结）────────────────────────────────
model AuditReport {
  id          Int      @id @default(autoincrement())

  /// 报告类型：'WEEK' | 'MONTH' | 'YEAR'
  reportType  String

  /// 周期编码，例如 '2026-W11'、'2026-03'、'2026'
  periodCode  String

  /// AI 生成的总结内容（Markdown）
  content     String

  /// 报告生成时的原始数据快照（JSON 字符串，可选）
  snapshotData String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([reportType, periodCode])
  @@index([reportType])
  @@index([periodCode])
}
